@page
@model WebAppRazorPagesAchivers.Pages.DeleteUsersModel
@{
}


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">

                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Delete Confirmation</h4>
                </div>

                <div class="card-body">
                    <h5 class="text-danger mb-3">
                        Are you sure you want to delete this user?
                    </h5>

                    <div class="mb-3">
                        <p class="mb-1"><strong>Name:</strong></p>
                        <p class="text-muted">@Model._User.Name</p>
                    </div>

                    <div class="mb-3">
                        <p class="mb-1"><strong>Email:</strong></p>
                        <p class="text-muted">@Model._User.Email</p>
                    </div>

                    <form method="post" class="d-flex justify-content-between">
                        <input type="hidden" asp-for="_User.ID" />

                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </button>

                        <a asp-page="DisplayUsers" class="btn btn-secondary">
                            Cancel
                        </a>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>