@page
@model WebAppRazorPagesAchivers.Pages.EditUsersModel
@{
}



<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">


<body class="bg-light">

    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card shadow-lg p-4" style="width: 400px;">

            <h3 class="text-center mb-4">Edit Users</h3>

            <form method="post">

                <!-- Name -->
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" placeholder="Enter your name" required asp-for="_UsersData.Name">
                </div>

                <!-- Email -->
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="hidden" asp-for="_UsersData.ID" />
                    <input type="email" class="form-control" placeholder="Enter your email" required asp-for="_UsersData.Email">
                </div>

                <!-- Password -->
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" class="form-control" placeholder="Enter password" required asp-for="_UsersData.Password">
                </div>

                <!-- DOB -->
                <div class="mb-3">
                    <label class="form-label">Date of Birth</label>
                    <input type="date" class="form-control" required asp-for="_UsersData.Dob" />
                </div>

                <!-- Button -->
                <!-- Submit Button -->
                <input type="submit" class="btn btn-primary w-100" value="Update Changes" />

                <br><br>

                <!-- Login Button (Razor Pages) -->
                <a asp-page="/DisplayUsers" class="btn btn-outline-primary w-100">
                    Back to List!
                </a>

            </form>

        </div>
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
