@page
@model WebAppRazorPagesAchivers.Pages.ProductsModel
@{
}
<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">


<body class="bg-light">

    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card shadow-lg p-4" style="width: 400px;">

            <h3 class="text-center mb-4">Products</h3>

            <form method="post">

                <!-- Product Name -->
                <div class="mb-3">
                    <label class="form-label">Product Name</label>
                    <input type="text" class="form-control" placeholder="Enter Product Name" required asp-for="_products.ProductName">
                </div>

                <!-- Cost -->
                <div class="mb-3">
                    <label class="form-label">Cost</label>
                    <input type="number" class="form-control" placeholder="Enter Cost" required asp-for="_products.Cost">
                </div>

                <!-- Qty -->
                <div class="mb-3">
                    <label class="form-label">Qty</label>
                    <input type="number" class="form-control" placeholder="Enter Qty" required asp-for="_products.Qty">
                </div>

               

                <!-- Button -->
                <!-- Submit Button -->
                <input type="submit" class="btn btn-primary w-100" value="Save Data" />

                <br><br>

               

            </form>

        </div>
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
