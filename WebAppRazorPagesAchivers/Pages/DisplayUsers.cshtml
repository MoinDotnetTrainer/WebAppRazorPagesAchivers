@page
@model WebAppRazorPagesAchivers.Pages.DisplayUsersModel
@{
}


<!-- Bootstrap 5 -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<body class="bg-light">

    <div class="container mt-5">

        <h3 class="mb-4 text-center">User Details Table</h3>

        <div class="card shadow-sm">
            <div class="card-body">

                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">

                        <thead class="table-primary">
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Password</th>
                                <th>Dob</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        @foreach (var item in Model._usersdata)
                        {
                            <tbody>
                                <tr>
                                    <td>@item.ID</td>
                                    <td>@item.Name</td>
                                    <td>@item.Email</td>
                                    <td>@item.Password</td>
                                    <td>@item.Dob</td>
                                    <td>
                                        <a href="EditUsers?ID=@item.ID">Edit</a>|
                                        <a href="DeleteUsers?ID=@item.ID">Delete</a>
                                    </td>
                                    @* <td><span class="badge bg-success">Active</span></td> *@
                                </tr>
                            </tbody>
                        }

                    </table>
                </div>

            </div>
        </div>

    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
